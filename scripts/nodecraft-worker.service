[Unit]
Description=NodeCraft Worker
After=network.target

[Service]
Type=simple
User=nodecraft
WorkingDirectory=/opt/nodecraft/worker
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
EnvironmentFile=/opt/nodecraft/worker/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nodecraft-worker

[Install]
WantedBy=multi-user.target
