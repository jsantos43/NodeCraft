{
  "openapi": "3.0.0",
  "info": {
    "title": "NodeCraft",
    "version": "1.0.0",
    "description": "API para gerenciar servidores de jogos via Docker"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3000"
    }
  ],
  "paths": {
    "/user/all": {
      "$ref": "./paths/user/all.json"
    },
    "/user": {
      "$ref": "./paths/user/index.json"
    },
    "/user/{id}": {
      "$ref": "./paths/user/id.json"
    },
    "/auth/login": {
      "$ref": "./paths/auth/login.json"
    },
    "/auth/logout": {
      "$ref": "./paths/auth/logout.json"
    },
    "/auth/refresh": {
      "$ref": "./paths/auth/refresh.json"
    },
    "/auth/verify": {
      "$ref": "./paths/auth/verify.json"
    },
    "/auth/validate": {
      "$ref": "./paths/auth/validate.json"
    },
    "/auth/forgot": {
      "$ref": "./paths/auth/forgot.json"
    },
    "/auth/reset": {
      "$ref": "./paths/auth/reset.json"
    },
    "/instance": {
      "$ref": "./paths/instance/index.json"
    },
    "/instance/{id}": {
      "$ref": "./paths/instance/id.json"
    },
    "/instance/{id}/run": {
      "$ref": "./paths/instance/run.json"
    },
    "/instance/{id}/stop": {
      "$ref": "./paths/instance/stop.json"
    },
    "/instance/{id}/restart": {
      "$ref": "./paths/instance/restart.json"
    },
    "/instance/{id}/backup": {
      "$ref": "./paths/instance/backup.json"
    },
    "/instance/{id}/remap": {
      "$ref": "./paths/instance/remap.json"
    },
    "/instance/{id}/link": {
      "$ref": "./paths/link/index.json"
    },
    "/instance/{id}/link/{linkId}": {
      "$ref": "./paths/link/linkId.json"
    },
    "/instance/{id}/files": {
      "$ref": "./paths/file/read.json"
    },
    "/instance/{id}/files/create": {
      "$ref": "./paths/file/create.json"
    },
    "/instance/{id}/files/upload": {
      "$ref": "./paths/file/upload.json"
    },
    "/instance/{id}/files/edit": {
      "$ref": "./paths/file/edit.json"
    },
    "/instance/{id}/files/delete": {
      "$ref": "./paths/file/delete.json"
    },
    "/instance/{id}/files/transfer": {
      "$ref": "./paths/file/transfer.json"
    },
    "/instance/{id}/files/unzip": {
      "$ref": "./paths/file/unzip.json"
    },
    "/": {
      "get": {
        "summary": "root",
        "responses": {}
      }
    }
  }
}