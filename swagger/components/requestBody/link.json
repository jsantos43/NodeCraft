{
  "default": {
    "content": {
      "application/json": {
        "schema": {
          "properties": {
            "userId": {
              "type": "string",
              "example": "1e7ca2e6-519d-45af-ba5f-18305979ac8b"
            },
            "gamertags": {
              "type": "array",
              "example": [
                "JPGamerPlay"
              ]
            },
            "permissions": {
              "type": "array",
              "example": [
                "instance:read",
                "instance:execute"
              ]
            },
            "privileges": {
              "type": "boolean",
              "example": true
            },
            "access": {
              "type": "string",
              "example": "always"
            }
          }
        }
      }
    }
  }
}