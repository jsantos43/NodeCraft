{
  "createUser": {
    "content": {
      "application/json": {
        "schema": {
          "properties": {
            "name": {
              "type": "string",
              "example": "Joao"
            },
            "email": {
              "type": "string",
              "example": "joao@email.com"
            },
            "password": {
              "type": "string",
              "example": "nodecraft123456"
            }
          }
        }
      }
    }
  },
  "updateUser": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "example": "Joao Pedro"
            }
          }
        }
      }
    }
  },
  "updateAnotherUser": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "example": "Joao Pedro"
            },
            "quota": {
              "type": "integer",
              "example": 3
            }
          }
        }
      }
    }
  }
}