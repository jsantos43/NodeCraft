{
  "name": "nodecraft",
  "version": "3.0.0",
  "description": "A node api to host server games",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:migrate:undo:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status"
  },
  "keywords": [
    "api",
    "minecraft",
    "server",
    "node",
    "docker"
  ],
  "author": "João Pedro Tomaz dos Santos",
  "license": "ISC",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.20.0",
    "nodemailer": ">=9.0.1",
    "pino": "^10.3.1",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/create-config": "eslint/create-config",
    "eslint": "^7.32.0 || ^8.2.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.25.2",
    "nodemon": "^3.1.14",
    "socket.io-client": "^4.8.3"
  }
}
