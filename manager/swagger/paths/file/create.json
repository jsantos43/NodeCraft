{
  "post": {
    "summary": "create File",
    "description": "Creates a file or directory at `destiny` inside the instance game folder. Proxied to the worker. Requires `instance:files:write`.",
    "tags": [
      "Files"
    ],
    "parameters": [
      {
        "name": "destiny",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "/hello.txt"
      }
    ],
    "responses": {
      "201": {
        "$ref": "../../components/responses/file.json#/create"
      },
      "400": {
        "$ref": "../../components/responses/error.json#/InvalidRequest"
      },
      "401": {
        "$ref": "../../components/responses/error.json#/Unathorized"
      },
      "403": {
        "$ref": "../../components/responses/error.json#/Forbidden"
      },
      "404": {
        "$ref": "../../components/responses/error.json#/NotFound"
      },
      "500": {
        "$ref": "../../components/responses/error.json#/Internal"
      }
    },
    "requestBody": {
      "$ref": "../../components/requestBody/file.json#/create"
    }
  },
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "required": true,
      "deprecated": false,
      "schema": {},
      "example": "76ad39e5-827f-4e0f-9715-e590be710595"
    }
  ]
}
