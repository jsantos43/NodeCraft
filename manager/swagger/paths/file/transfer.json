{
  "post": {
    "summary": "copy/move File",
    "tags": [
      "Files"
    ],
    "parameters": [
      {
        "name": "path",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "/world"
      },
      {
        "name": "destiny",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "/world-backup"
      },
      {
        "name": "actions",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string",
          "enum": [
            "copy",
            "move"
          ]
        },
        "example": "copy"
      }
    ],
    "responses": {
      "200": {
        "$ref": "../../components/responses/file.json#/transfer"
      },
      "400": {
        "$ref": "../../components/responses/error.json#/InvalidRequest"
      },
      "401": {
        "$ref": "../../components/responses/error.json#/Unathorized"
      },
      "403": {
        "$ref": "../../components/responses/error.json#/Forbidden"
      },
      "404": {
        "$ref": "../../components/responses/error.json#/NotFound"
      },
      "500": {
        "$ref": "../../components/responses/error.json#/Internal"
      }
    }
  },
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "required": true,
      "deprecated": false,
      "schema": {},
      "example": "76ad39e5-827f-4e0f-9715-e590be710595"
    }
  ]
}