{
  "post": {
    "summary": "unzip File",
    "description": "Extracts the zip at `path` into `destiny` inside the instance game folder. Proxied to the worker. Requires `instance:files:write`.",
    "tags": [
      "Files"
    ],
    "parameters": [
      {
        "name": "path",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "/backup.zip"
      },
      {
        "name": "destiny",
        "in": "query",
        "required": true,
        "schema": {
          "type": "string"
        },
        "example": "/backup"
      }
    ],
    "responses": {
      "200": {
        "$ref": "../../components/responses/file.json#/unzip"
      },
      "400": {
        "$ref": "../../components/responses/error.json#/InvalidRequest"
      },
      "401": {
        "$ref": "../../components/responses/error.json#/Unathorized"
      },
      "403": {
        "$ref": "../../components/responses/error.json#/Forbidden"
      },
      "404": {
        "$ref": "../../components/responses/error.json#/NotFound"
      },
      "500": {
        "$ref": "../../components/responses/error.json#/Internal"
      }
    }
  },
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "required": true,
      "schema": {
        "type": "string"
      },
      "example": "76ad39e5-827f-4e0f-9715-e590be710595"
    }
  ]
}
