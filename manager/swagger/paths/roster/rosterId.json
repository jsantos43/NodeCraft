{
  "get": {
    "summary": "read a Roster entry",
    "description": "Reads a single roster entry by id. Requires the `instance:read` permission.",
    "tags": [
      "Roster"
    ],
    "responses": {
      "200": {
        "$ref": "../../components/responses/roster.json#/default"
      },
      "401": {
