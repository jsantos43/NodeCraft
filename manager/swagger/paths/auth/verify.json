{
  "post": {
    "summary": "verify User account",
    "description": "Sends (or re-sends) the account-verification email to the logged-in user. Returns 400 if the account is already verified. Requires a valid access token and the email service.",
    "tags": [
      "Auth"
    ],
    "responses": {
      "200": {
        "$ref": "../../components/responses/user.json#/default"
      },
      "400": {
        "$ref": "../../components/responses/auth.json#/alreadyVerified"
      },
      "401": {
        "$ref": "../../components/responses/error.json#/Unathorized"
      },
      "500": {
        "$ref": "../../components/responses/error.json#/Internal"
      },
      "503": {
        "$ref": "../../components/responses/error.json#/UnavailableService"
      }
    }
  }
}
