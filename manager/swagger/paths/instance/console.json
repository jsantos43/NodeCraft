{
  "post": {
    "summary": "generate a console access token for a Instance",
    "description": "Issues a short-lived (120s) JWT the frontend uses to open the console WebSocket directly on the worker. The token carries `console:read`, plus `console:write` when the user has that permission. Requires `instance:console:read`.",
    "tags": [
      "Instance"
    ],
    "responses": {
      "200": {
        "$ref": "../../components/responses/instance.json#/console"
      },
      "400": {
        "$ref": "../../components/responses/error.json#/InvalidRequest"
      },
      "401": {
        "$ref": "../../components/responses/error.json#/Unathorized"
      },
      "403": {
        "$ref": "../../components/responses/error.json#/Forbidden"
      },
      "404": {
        "$ref": "../../components/responses/error.json#/NotFound"
      },
      "500": {
        "$ref": "../../components/responses/error.json#/Internal"
      }
    }
  },
  "parameters": [
    {
      "name": "id",
      "in": "path",
      "required": true,
      "schema": {
        "type": "string"
      },
      "example": "76ad39e5-827f-4e0f-9715-e590be710595"
    }
  ]
}
