{
  "openapi": "3.0.0",
  "info": {
    "title": "NodeCraft",
    "version": "1.0.0",
    "description": "Central manager API for the NodeCraft game-server hosting platform. It handles authentication, users and quotas, game instances (create/configure/run/backup), per-instance sharing via links, file management (proxied to the workers) and the worker fleet that runs the instances via Docker.\n\n**Authentication:** most routes require a JWT access token (15min) sent in the `accessToken` httpOnly cookie, refreshed through `/auth/refresh`. Some routes are admin only, and the `/worker/*` reporting routes are called by the workers themselves using their API key."
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Login, token refresh/logout, account verification and password reset."
    },
    {
      "name": "User",
      "description": "User accounts, profile updates and admin-managed quotas/limits."
    },
    {
      "name": "Instance",
      "description": "Game server instances: create, configure, run/stop/restart, backup, console access and ownership/worker placement."
    },
    {
      "name": "Files",
      "description": "File manager for an instance's game folder — proxied to the worker that hosts it."
    },
    {
      "name": "Link",
      "description": "Shared-access grants that let non-owners use an instance with scoped permissions."
    },
    {
      "name": "Worker",
      "description": "Worker fleet management and the worker→manager reporting routes (heartbeats, instance status, backup results)."
    }
  ],
  "paths": {
    "/user/all": {
      "$ref": "./paths/user/all.json"
    },
    "/user": {
      "$ref": "./paths/user/index.json"
    },
    "/user/{id}": {
      "$ref": "./paths/user/id.json"
    },
    "/auth/login": {
      "$ref": "./paths/auth/login.json"
    },
    "/auth/refresh": {
      "$ref": "./paths/auth/refresh.json"
    },
    "/auth/logout": {
      "$ref": "./paths/auth/logout.json"
    },
    "/auth/verify": {
      "$ref": "./paths/auth/verify.json"
    },
    "/auth/validate": {
      "$ref": "./paths/auth/validate.json"
    },
    "/auth/forgot": {
      "$ref": "./paths/auth/forgot.json"
    },
    "/auth/reset": {
      "$ref": "./paths/auth/reset.json"
    },
    "/instance": {
      "$ref": "./paths/instance/index.json"
    },
    "/instance/{id}": {
      "$ref": "./paths/instance/id.json"
    },
    "/instance/{id}/permissions": {
      "$ref": "./paths/instance/permissions.json"
    },
    "/instance/{id}/owner": {
      "$ref": "./paths/instance/owner.json"
    },
    "/instance/{id}/worker": {
      "$ref": "./paths/instance/worker.json"
    },
    "/instance/{id}/console": {
      "$ref": "./paths/instance/console.json"
    },
    "/instance/{id}/run": {
      "$ref": "./paths/instance/run.json"
    },
    "/instance/{id}/stop": {
      "$ref": "./paths/instance/stop.json"
    },
    "/instance/{id}/restart": {
      "$ref": "./paths/instance/restart.json"
    },
    "/instance/{id}/backup": {
      "$ref": "./paths/instance/backup.json"
    },
    "/instance/{id}/remap": {
      "$ref": "./paths/instance/remap.json"
    },
    "/instance/{id}/link": {
      "$ref": "./paths/link/index.json"
    },
    "/instance/{id}/link/{linkId}": {
      "$ref": "./paths/link/linkId.json"
    },
    "/instance/{id}/files": {
      "$ref": "./paths/file/read.json"
    },
    "/instance/{id}/files/create": {
      "$ref": "./paths/file/create.json"
    },
    "/instance/{id}/files/upload": {
      "$ref": "./paths/file/upload.json"
    },
    "/instance/{id}/files/edit": {
      "$ref": "./paths/file/edit.json"
    },
    "/instance/{id}/files/delete": {
      "$ref": "./paths/file/delete.json"
    },
    "/instance/{id}/files/transfer": {
      "$ref": "./paths/file/transfer.json"
    },
    "/instance/{id}/files/unzip": {
      "$ref": "./paths/file/unzip.json"
    },
    "/worker": {
      "$ref": "./paths/worker/index.json"
    },
    "/worker/all": {
