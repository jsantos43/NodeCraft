    },
    "/": {
      "get": {
        "summary": "API root",
        "description": "Public health/info endpoint. Returns basic API metadata (name, version, docs link and author). No authentication required.",
        "tags": [
          "Root"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "name": {
                      "type": "string",
                      "example": "Nodecraft API"
                    },
                    "version": {
                      "type": "string",
                      "example": "3.0"
                    },
                    "summary": {
                      "type": "string",
                      "example": "Central manager API of the NodeCraft platform — create, configure and run game server instances via Docker, with authentication, per-instance permissions, automatic backups and worker fleet monitoring."
                    },
                    "docs": {
                      "type": "string",
                      "example": "/docs"
                    },
                    "github": {
                      "type": "string",
                      "example": "https://github.com/jsantos43"
                    },
                    "author": {
                      "type": "string",
                      "example": "João Pedro Tomaz dos Santos"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}