    },
    "name": {
      "type": "string",
      "example": "worker-sp-01"
    },
    "url": {
      "type": "string",
      "nullable": true,
      "example": "http://worker.webisk.com.br:9184"
    },
    "healthy": {
      "type": "boolean",
      "example": true
    },
    "lastSeenAt": {
