      "example": 23.5
    },
    "memorieTotal": {
      "type": "integer",
      "nullable": true,
      "description": "Total memory in MB.",
      "example": 16384
    },
    "memorieUsed": {
      "type": "integer",
      "nullable": true,
      "description": "Used memory in MB.",
      "example": 4096
    },
    "diskAvailable": {
      "type": "integer",
      "nullable": true,
      "description": "Available disk in MB.",
      "example": 204800
    }
