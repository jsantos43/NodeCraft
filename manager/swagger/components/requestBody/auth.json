{
  "login": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "example": "joao@email.com"
            },
            "password": {
              "type": "string",
              "example": "nodecraft123456"
            }
          }
        }
      }
    }
  },
  "validate": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "example": "70e942b1a1604772acd0c0b2958e8d4862d4af5b41955b80be2d4c0746c1ceeee735b3374156bc5e925811e91682ff3b1462e7e71692b52e06b4c2daa2821413"
            }
          }
        }
      }
    }
  },
  "forgot": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "email": {
              "type": "string",
              "format": "email",
              "example": "joao@email.com"
            }
          }
        }
      }
    }
  },
  "resetPassword": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "properties": {
            "token": {
              "type": "string",
              "example": "eea07ccc96ed4bade91405eb9f68922b5e431eee0fbc4d0aaa82b25f4d97e7232c694f97b8948afd5a1f14af622dff74c491a567137f9310c6ae72754f2e90f2"
            },
            "password": {
              "type": "string",
              "example": "nodecraft123456"
            }
          }
        }
      }
    }
  }
}