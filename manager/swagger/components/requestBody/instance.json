{
  "create": {
    "content": {
      "application/json": {
        "schema": {
          "type": "object",
          "required": [
            "name",
            "type"
          ],
          "properties": {
            "name": {
              "type": "string",
              "example": "Meu mundo de minecraft",
              "minLength": 3,
              "maxLength": 32
            },
            "type": {
              "type": "string",
              "enum": [
                "minecraft",
                "hytale",
                "counterstrike",
                "terraria",
                "kerbal"
              ],
              "example": "minecraft"
            },
            "game": {
              "oneOf": [
                {
                  "$ref": "../schemas/minecraft.json"
                },
                {
                  "$ref": "../schemas/hytale.json"
                },
                {
                  "$ref": "../schemas/kerbal.json"
                },
                {
                  "$ref": "../schemas/terraria.json"
                },
                {
                  "$ref": "../schemas/counterstrike.json"
                }
              ]
            }
          }
        }
      }
    }
  }
}